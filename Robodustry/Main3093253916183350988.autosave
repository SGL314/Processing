void draw() {
  // inicial
  translate(transX,transY);
  scale(zoom);
  background(0);
  //
  //
  // codigo normal
  formGrid();
  for(Particle p: particles) {
    if (running) p.update();
    p.show();
  }
  //
  //
  // clique do mouse
  mouseAutomatic();
  // volta zoom e translate pra colocar no lugar na tela
  scale(1 / zoom);
  translate(-transX, -transY);
  // mouse position
  if (Cfg.showPosition) {
    textSize(16);
    fill(128,64,64);
    text(mouseX + "," + mouseY, mouseX,mouseY);
  }
  //
  showMenus();
  //
  //
  // codigo sem translate e zoom
  //
  //
  // textSize(16);
  // fill(255);
  // text(10 + " " + 10, 20, 20);

  // if (showConfigs) {
    // 	configs();
    // }
  // loop
  loop += 1;
}

void formGrid() {
  // grid geral
  fill(255,255,255);
  float center = 0;
  // if (tamGrid/2*tamSquare < width/2)
  center = width / 2 - tamGrid / 2 * tamSquare;
  for (int i=0; i<tamGrid; i++) {
    stroke(1);
    for (int j=0; j<tamGrid; j++) {
      rect(tamSquare * i + center,tamSquare * j + center,tamSquare,tamSquare);
    }
  }
}

