import java.nio.file.Files;
import java.nio.file.Path;

class Particle {
  float x;
  float y;
  float vx;
  float vy;
  float r;
  String type;
  int cor;
  boolean shined = false,selected = false;
  //

  Particle(String type,float x, float y) {
    this.type = type;
    this.x = x;
    this.y = y;
    r = 10;
    cor = color(255,0,0);
  }

  void update() {
    this.x += this.vx;
    this.y += this.vy;
  }

  void show() {
    noStroke();
    fill(cor);
    ellipse(x,y,r,r);
  }
}
